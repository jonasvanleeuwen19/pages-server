# The url of your Forgejo/Gitea instance
GITEA_URL=https://git.example.com
# Your Forgejo/Gitea access token
GITEA_TOKEN=your_access_token_here
# The main domain where you host all the pages, for example USERNAME.pages.example.com
MAIN_DOMAIN=pages.example.com
# The public instance name used in titles and the landing page
INSTANCE_NAME=Tuxforge Pages
# The name of the default branch with static files for pages
GITEA_BRANCH_NAME=pages
# Allow Forgejo/Gitea requests over HTTP or not
GITEA_VERIFY_SSL=true
# The logo on error pages and the landing page
LOGO_URL=https://example.com/logo.png
# The favicon shown in the browser tab
FAVICON_URL=https://example.com/favicon.ico
# The public base URL of this Pages server, used for Forgejo OAuth redirects
PUBLIC_URL=https://pages.example.com
# OAuth application client ID from Forgejo user settings -> applications
FORGEJO_OAUTH_CLIENT_ID=your_oauth_client_id_here
# OAuth application client secret from Forgejo user settings -> applications
FORGEJO_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
# The folder where you want to clone the repo's
PAGES_ROOT=./pages
# If you put GITEA_BRANCH_NAME on main or master you can host the page from one of the folders here without needing an extra branch for pages
PAGES_PUBLISH_DIRS=.,site,public,dist,build
# The folder where the landing and error templates live
TEMPLATES_DIR=./templates
# The web port to host your Tuxforge Pages instance
WEB_PORT=8080
# Optional explicit webhook target, defaults to https://MAIN_DOMAIN
PAGES_WEBHOOK_URL=https://pages.example.com

# Forgejo OAuth callback URI to register in your application:
# https://pages.example.com/oauth/callback
